datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator pyclient {
  provider = "prisma-client-py"
  interface = "asyncio"
}

model User {
  id        String    @id @default(uuid()) // Can map to Clerk User ID
  email     String    @unique
  name      String?
  
  projects  Project[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete support

  @@index([email])
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  
  documents   Document[]
  stories     UserStory[]
  sprints     SprintPlan[]
  reports     Report[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete support

  @@index([userId])
}

model Document {
  id        String    @id @default(uuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  
  fileName  String
  fileUrl   String
  fileType  String
  status    DocStatus @default(PENDING)
  
  analysis  RequirementAnalysis?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete support

  @@index([projectId])
  @@index([status])
}

enum DocStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
}

model RequirementAnalysis {
  id             String    @id @default(uuid())
  documentId     String    @unique
  document       Document  @relation(fields: [documentId], references: [id])
  
  businessGoals  Json      // Stores array of goals
  stakeholders   Json      // Stores array of stakeholder definitions
  rawExtracted   String?   @db.Text
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // Soft delete support

  @@index([documentId])
}

model UserStory {
  id             String    @id @default(uuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id])
  
  sprintPlanId   String?
  sprintPlan     SprintPlan? @relation(fields: [sprintPlanId], references: [id])
  
  title          String
  description    String    @db.Text
  storyPoints    Int?
  priority       Priority  @default(MEDIUM)
  status         StoryStatus @default(DRAFT)
  
  criteria       AcceptanceCriteria[]
  jiraTicket     JiraTicket?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // Soft delete support

  @@index([projectId])
  @@index([sprintPlanId])
  @@index([priority])
  @@index([status])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StoryStatus {
  DRAFT
  REFINED
  READY
  IN_PROGRESS
  DONE
}

model AcceptanceCriteria {
  id          String    @id @default(uuid())
  storyId     String
  story       UserStory @relation(fields: [storyId], references: [id])
  
  description String    @db.Text
  isMet       Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete support

  @@index([storyId])
}

model SprintPlan {
  id        String      @id @default(uuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id])
  
  name      String
  goal      String?     @db.Text
  startDate DateTime?
  endDate   DateTime?
  
  stories   UserStory[]
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime? // Soft delete support

  @@index([projectId])
}

model JiraTicket {
  id            String    @id @default(uuid())
  storyId       String    @unique
  story         UserStory @relation(fields: [storyId], references: [id])
  
  jiraIssueId   String    // Internal Jira ID
  jiraIssueKey  String    // e.g., PROJ-123
  jiraUrl       String
  syncStatus    SyncStatus @default(PENDING)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete support

  @@index([storyId])
  @@index([jiraIssueKey])
  @@index([syncStatus])
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

model Report {
  id        String    @id @default(uuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  
  name      String
  reportUrl String    // S3/UploadThing URL
  type      ReportType
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete support

  @@index([projectId])
}

enum ReportType {
  SPRINT_SUMMARY
  PROJECT_OVERVIEW
  REQUIREMENTS_TRACEABILITY
}
